{
  "rewrites": [
    { "source": "/abholung",          "destination": "/abholung.html" },
    { "source": "/pickup",            "destination": "/PickUp-Ranger.html" },
    { "source": "/pickup-ranger",     "destination": "/PickUp-Ranger.html" },
    { "source": "/pickup-ranger.html","destination": "/PickUp-Ranger.html" },
    { "source": "/ranger",            "destination": "/PickUp-Ranger.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ]
}
